# Database
DATABASE_URL=postgresql+psycopg2://scout:scout@localhost:5438/scout
DB_PASSWORD=scout
# Same Postgres instance as DATABASE_URL, separate DB for integration tests.
# Run migrations against this URL before running integration tests:
#   DATABASE_URL=$TEST_DATABASE_URL alembic upgrade head
TEST_DATABASE_URL=postgresql+psycopg2://scout:scout@localhost:5438/scout_test

# API Keys
OPENAI_API_KEY=your-openai-api-key
PUBMED_API_KEY=your-pubmed-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
NCBI_API_KEY=your-ncbi-api-key
OPENFDA_API_KEY=your-openfda-api-key

# LLM Settings
LLM_MODEL=claude-sonnet-4-6
SMALL_LLM_MODEL=claude-haiku-4-5-20251001
EMBEDDING_MODEL=FremyCompany/BioLORD-2023

# App Settings
DEBUG=false
LOG_LEVEL=INFO

# File cache dir. Leave unset for native (.venv) runs so the cache falls back
# to <root>/cache. In Docker/Railway set SCOUT_CACHE_DIR=/cache to match the
# mounted persistent volume (scout_cache:/cache).
# SCOUT_CACHE_DIR=/cache

# Tunable limits live in .env.constants (see .env.constants.example).
# To swap constants at runtime:
#   CONSTANTS_FILE=.env.constants.test pytest
#   CONSTANTS_FILE=.env.constants.experiment scout find -d "metformin"

LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL="https://us.cloud.langfuse.com"