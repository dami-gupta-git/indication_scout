# Tunable limits — SMOKE profile. Bare-minimum coverage to exercise the full
# pipeline end-to-end as fast as possible. Output is NOT scientifically usable —
# use only to check that a run completes / wiring works.
#   CONSTANTS_FILE=.env.constants.smoke scout find -d "metformin"
# Every field must be present — config.py has no defaults.

# LLM token limits
LLM_MAX_TOKENS=2048              # was 4096 — shorter generations
SMALL_LLM_MAX_TOKENS=512        # was 1024

# Base client
DEFAULT_TIMEOUT=30.0
DEFAULT_MAX_RETRIES=2           # was 3 — fail fast

# Literature / RAG
LITERATURE_TOP_K=3              # was 15 — minimal abstracts to synthesize
SEMANTIC_SEARCH_TOP_K=3         # was 5
PUBMED_MAX_RESULTS=20           # was 200 — tiny PubMed fetch
PUBMED_SEARCH_DEFAULT_MAX_RESULTS=20   # was 50
PUBMED_ESUMMARY_BATCH_SIZE=200
PUBMED_EFETCH_BATCH_SIZE=100
RAG_LLM_CONCURRENCY=6           # was 4 — free parallelism
RAG_PUBMED_CONCURRENCY=5        # was 3 — free parallelism
RAG_DISEASE_CONCURRENCY=4

# Clinical trials
CLINICAL_TRIALS_LANDSCAPE_MAX_TRIALS=5   # was 50 — few exemplars; counts unaffected
CLINICAL_TRIALS_CAP=5                     # was 20

# Supervisor
SUPERVISOR_CANDIDATE_CAP=3      # was 15 — short final list

# Mechanism — high thresholds + tiny cap starve the candidate list so the
# supervisor investigates fewer diseases (the real per-run multiplier).
MECHANISM_SIGNAL_THRESHOLD=0.6  # was 0.4
MECHANISM_ASSOCIATIONS_CAP=3    # was 10

# Disease helper
DISEASE_PUBMED_MIN_RESULTS=1    # was 3

# Open Targets
OPEN_TARGETS_PAGE_SIZE=200             # was 500
OPEN_TARGETS_COMPETITOR_PREFETCH_MAX=10   # was 40 — fewer competitor candidates
OPEN_TARGETS_ASSOCIATION_MIN_SCORE=0.3    # was 0.1 — only strong associations

# Supervisor parallel fan-out (smoke testing only)
SUPERVISOR_FANOUT=true
