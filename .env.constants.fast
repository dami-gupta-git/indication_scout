# Tunable limits — FAST profile. Trades coverage/accuracy for speed.
# Opt-in per run; production .env.constants is untouched:
#   CONSTANTS_FILE=.env.constants.fast scout find -d "metformin"
# Every field below must be present — config.py has no defaults, so a missing
# field fails startup. Values diverging from .env.constants are flagged inline.

# LLM token limits
LLM_MAX_TOKENS=4096
SMALL_LLM_MAX_TOKENS=1024

# Base client
DEFAULT_TIMEOUT=30.0
DEFAULT_MAX_RETRIES=3

# Literature / RAG
LITERATURE_TOP_K=10              # was 15 — fewer abstracts to synthesize LLM
SEMANTIC_SEARCH_TOP_K=5
PUBMED_MAX_RESULTS=100           # was 200 — halves PMIDs fetched + embedded
PUBMED_SEARCH_DEFAULT_MAX_RESULTS=50
PUBMED_ESUMMARY_BATCH_SIZE=200
PUBMED_EFETCH_BATCH_SIZE=100
RAG_LLM_CONCURRENCY=6            # was 4 — free: more parallel LLM calls
RAG_PUBMED_CONCURRENCY=5         # was 3 — free: NCBI key allows 10 req/s, capped at 8
RAG_DISEASE_CONCURRENCY=4

# Clinical trials
CLINICAL_TRIALS_LANDSCAPE_MAX_TRIALS=25   # was 50 — fewer exemplars; counts unaffected
CLINICAL_TRIALS_CAP=10                     # was 20 — fewer exemplar records fetched/formatted

# Supervisor
SUPERVISOR_CANDIDATE_CAP=15

# Mechanism
MECHANISM_SIGNAL_THRESHOLD=0.4
MECHANISM_ASSOCIATIONS_CAP=10

# Disease helper
DISEASE_PUBMED_MIN_RESULTS=3

# Open Targets
OPEN_TARGETS_PAGE_SIZE=500
OPEN_TARGETS_COMPETITOR_PREFETCH_MAX=40
OPEN_TARGETS_ASSOCIATION_MIN_SCORE=0.1
